<div class="view-header">
    <h1>Catálogo de Productos</h1>
    <p>Explora nuestro catálogo con paginación, filtros por categoría o disponibilidad y ordenamiento por precio.</p>
</div>

<!-- Panel de Filtros y Ordenamiento -->
<section class="filters-panel">
    <form action="/products" method="GET" class="filters-form">
        <div class="filter-group">
            <label for="query">Buscar / Filtro:</label>
            <input type="text" id="query" name="query" value="{{query}}" placeholder="Categoría (ej: Electrónica) o disponibilidad">
        </div>

        <div class="filter-group">
            <label for="sort">Ordenar por Precio:</label>
            <select id="sort" name="sort">
                <option value="" {{#unless sort}}selected{{/unless}}>Sin ordenamiento</option>
                <option value="asc" {{#if (eq sort "asc")}}selected{{/if}}>Precio: Menor a Mayor</option>
                <option value="desc" {{#if (eq sort "desc")}}selected{{/if}}>Precio: Mayor a Menor</option>
            </select>
        </div>

        <div class="filter-group">
            <label for="limit">Por página:</label>
            <select id="limit" name="limit">
                <option value="5" {{#if (eq limit "5")}}selected{{/if}}>5</option>
                <option value="10" {{#if (eq limit "10")}}selected{{/if}}>10 (Default)</option>
                <option value="20" {{#if (eq limit "20")}}selected{{/if}}>20</option>
            </select>
        </div>

        <button type="submit" class="btn btn-primary">Aplicar Filtros</button>
        <a href="/products" class="btn btn-secondary">Limpiar</a>
    </form>
</section>

<div class="catalog-section">
    {{#if error}}
        <div class="alert alert-danger">{{error}}</div>
    {{/if}}

    <div class="products-grid">
        {{#each products}}
            <div class="product-card">
                <div class="product-badge">{{this.category}}</div>
                <div class="product-content">
                    <h3 class="product-title">{{this.title}}</h3>
                    <p class="product-desc">{{this.description}}</p>
                    <div class="product-meta">
                        <span class="product-code">Código: <strong>{{this.code}}</strong></span>
                        <span class="product-stock {{#if this.stock}}in-stock{{else}}no-stock{{/if}}">
                            {{#if this.stock}}En Stock ({{this.stock}}){{else}}Sin Stock{{/if}}
                        </span>
                    </div>
                </div>
                <div class="product-footer">
                    <span class="product-price">${{this.price}}</span>
                    <span class="product-id">ID: {{this._id}}</span>
                </div>
                <div class="product-actions-bar">
                    <a href="/products/{{this._id}}" class="btn btn-detail">🔍 Ver Detalle</a>
                    <button class="btn btn-add-cart" data-id="{{this._id}}">🛒 Agregar al Carrito</button>
                </div>
            </div>
        {{else}}
            <div class="empty-state">
                <p>No se encontraron productos que coincidan con la búsqueda.</p>
            </div>
        {{/each}}
    </div>

    <!-- Paginación visual -->
    {{#if totalPages}}
        <div class="pagination-container">
            <div class="pagination-info">
                Página <strong>{{page}}</strong> de <strong>{{totalPages}}</strong>
            </div>
            <div class="pagination-controls">
                {{#if hasPrevPage}}
                    <a href="{{prevLink}}" class="btn btn-pagination">← Anterior</a>
                {{else}}
                    <span class="btn btn-pagination disabled">← Anterior</span>
                {{/if}}

                {{#if hasNextPage}}
                    <a href="{{nextLink}}" class="btn btn-pagination">Siguiente →</a>
                {{else}}
                    <span class="btn btn-pagination disabled">Siguiente →</span>
                {{/if}}
            </div>
        </div>
    {{/if}}
</div>
