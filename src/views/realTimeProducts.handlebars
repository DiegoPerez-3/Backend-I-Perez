<div class="view-header">
    <h1>Panel de Productos en Tiempo Real (WebSockets)</h1>
    <p>Esta vista utiliza WebSockets para actualizar el catálogo en tiempo real. Cualquier creación o eliminación se reflejará instantáneamente para todos los usuarios conectados.</p>
</div>

<div class="realtime-container">
    <!-- Formulario para agregar productos -->
    <section class="form-section">
        <h2>Agregar Nuevo Producto</h2>
        <form id="product-form" class="product-form">
            <div class="form-group">
                <label for="title">Título / Nombre</label>
                <input type="text" id="title" name="title" required placeholder="Ej: Teclado Mecánico">
            </div>

            <div class="form-group">
                <label for="description">Descripción</label>
                <input type="text" id="description" name="description" required placeholder="Ej: Teclado RGB switch blue">
            </div>

            <div class="form-group">
                <label for="code">Código de Identificación</label>
                <input type="text" id="code" name="code" required placeholder="Ej: TEC-001">
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="price">Precio ($)</label>
                    <input type="number" id="price" name="price" step="0.01" required placeholder="99.99">
                </div>

                <div class="form-group">
                    <label for="stock">Stock disponible</label>
                    <input type="number" id="stock" name="stock" required placeholder="10">
                </div>
            </div>

            <div class="form-group">
                <label for="category">Categoría</label>
                <input type="text" id="category" name="category" required placeholder="Ej: Computación">
            </div>

            <button type="submit" class="btn btn-submit">Crear Producto</button>
        </form>
    </section>

    <!-- Catálogo que se actualiza por WebSockets -->
    <section class="list-section">
        <h2>Catálogo de Productos en Tiempo Real</h2>
        <div id="realtime-products-container" class="products-grid">
            {{#each products}}
                <div class="product-card">
                    <div class="product-badge">{{this.category}}</div>
                    <div class="product-content">
                        <h3 class="product-title">{{this.title}}</h3>
                        <p class="product-desc">{{this.description}}</p>
                        <div class="product-meta">
                            <span class="product-code">Código: <strong>{{this.code}}</strong></span>
                            <span class="product-stock {{#if this.stock}}in-stock{{else}}no-stock{{/if}}">
                                Stock: {{this.stock}}
                            </span>
                        </div>
                    </div>
                    <div class="product-footer">
                        <span class="product-price">${{this.price}}</span>
                        <span class="product-id">ID: {{this.id}}</span>
                    </div>
                    <div class="product-actions-bar">
                        <button class="btn btn-delete" data-id="{{this.id}}">🗑️ Eliminar</button>
                    </div>
                </div>
            {{else}}
                <div class="empty-state">
                    <p>No hay productos registrados en el catálogo actualmente.</p>
                </div>
            {{/each}}
        </div>
    </section>
</div>

<!-- Cargamos Socket.io y el archivo JS específico de esta vista -->
<script src="/socket.io/socket.io.js"></script>
<script src="/js/realtime.js"></script>
